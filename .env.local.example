# === Kern ===
# Anthropic API-sleutel — gebruikt door de wekelijkse artikelworkflow
# (trendonderzoek, artikel schrijven, fotokeuze).
ANTHROPIC_API_KEY=sk-ant-...

# === Wekelijkse cron ===
# Willekeurig, lang, geheim. Vercel Cron stuurt dit mee als "Authorization: Bearer <CRON_SECRET>".
# Het endpoint weigert alles zonder de juiste waarde met 401.
CRON_SECRET=genereer-een-lange-random-string

# === Publiceren via GitHub ===
# Fine-grained Personal Access Token met "Contents: Read and write" op de repo.
GITHUB_TOKEN=github_pat_...
# Formaat: eigenaar/repo, bijv. jouwnaam/moestuincoach
GITHUB_REPO=owner/repo
# Branch waarop gepubliceerd wordt (Vercel herbouwt op een commit hierin).
GITHUB_BRANCH=main

# === Stockfoto's (Pexels) ===
# Gratis API-key via https://www.pexels.com/api/
# Zonder deze key valt de workflow terug op een nette standaardafbeelding.
PEXELS_API_KEY=

# === Meldingen (Resend) ===
# Wordt ook al gebruikt door het contactformulier.
RESEND_API_KEY=re_...
# Ontvanger van publicatie- en foutmeldingen.
NOTIFY_EMAIL=info@moestuin.nl

# === Optioneel ===
# publish (standaard) = artikel gaat live + mail. draft = wel genereren en
# committen als concept (status: draft, niet zichtbaar), geen mail.
ARTICLE_MODE=publish
# Model-overrides (optioneel). Standaard: claude-sonnet-5 voor onderzoek/schrijven,
# claude-haiku-4-5 voor de fotokeuze.
# ARTICLE_MODEL=claude-sonnet-5
# IMAGE_PICK_MODEL=claude-haiku-4-5
# Afzender voor alle transactionele mail (workflow-melding + contactformulier).
# Standaard onboarding@resend.dev (werkt zonder geverifieerd domein, maar mailt
# dan alleen naar je eigen Resend-account-adres). Na domeinverificatie bij Resend:
# zet deze op "Moestuin.nl <noreply@moestuin.nl>".
RESEND_FROM=Moestuin.nl <onboarding@resend.dev>
